meta {
  name: Create a cursor
  type: http
  seq: 1
}

post {
  url: {{host}}/_db/{{databaseName}}/_api/cursor
  body: json
  auth: basic
}

auth:basic {
  username: root
  password: test
}

body:json {
  {
    "query" : "LET products = (FOR v, e, p IN 0..100 INBOUND @startNode GRAPH 'default' FILTER PARSE_IDENTIFIER(v).collection == 'products' RETURN v) LET processes = (FOR v, e, p IN 0..100 INBOUND @startNode GRAPH 'default' FILTER PARSE_IDENTIFIER(v).collection == 'processes' RETURN v) LET inputs = (FOR v, e, p IN 0..100 INBOUND @startNode GRAPH 'default'    FILTER PARSE_IDENTIFIER(e).collection == 'inputs' RETURN e) LET outputs = (FOR v, e, p IN 0..100 INBOUND @startNode GRAPH 'default' FILTER PARSE_IDENTIFIER(e).collection == 'outputs' RETURN e) RETURN {products, processes, inputs, outputs}",
    "bindVars" :  {
                    "startNode" : "chicken/10000"
                  }
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
