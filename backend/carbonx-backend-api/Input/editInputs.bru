meta {
  name: editInputs
  type: http
  seq: 4
}

put {
  url: {{host}}/api/inputs/:companyName
  body: json
  auth: inherit
}

params:path {
  companyName: default
}

body:json {
  [
    {
      "productName": "auau",
      "processName": "salakau",
      "_key": "1"
    },
    {
      "productName": "singapore",
      "processName": "bobeychau",
      "_key": "2"
    }
  ]
}

settings {
  encodeUrl: true
  timeout: 0
}
