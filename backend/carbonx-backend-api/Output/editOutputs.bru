meta {
  name: editOutputs
  type: http
  seq: 4
}

put {
  url: {{host}}/api/outputs/:companyName
  body: json
  auth: inherit
}

params:path {
  companyName: default
}

body:json {
  [
    {
      "processName": "au",
      "productName": "au",
      "_key": "1"
    },
    {
      "processName": "sala",
      "productName": "kau",
      "_key": "2"
    }
  ]
}

settings {
  encodeUrl: true
  timeout: 0
}
