meta {
  name: editOutput
  type: http
  seq: 6
}

put {
  url: {{host}}/api/outputs/:companyName/:id
  body: json
  auth: inherit
}

params:path {
  companyName: default
  id: 1
}

body:json {
  {
    "processName": "salaku",
    "productName": "balaku"
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
