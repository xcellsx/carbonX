# Optional: override API base URL if your backend runs on a different host/port.
# Default is relative /api (uses Vite dev proxy to localhost:8080).
# Example: if backend is on port 8808:
# VITE_API_BASE_URL=http://localhost:8808
#
# Optional: change Vite proxy target for local development.
# VITE_API_PROXY_TARGET=http://localhost:8080
#
# Optional: backend company/database name used by /api/users/{companyName} endpoints.
# VITE_COMPANY_NAME=testCompany
#
# Optional: data database for products/processes/templates graph lookups.
# Current backend has 100 products/processes in "default".
# VITE_DATA_DATABASE=default
#
# Maritime ship logs + voyage LCA use a separate Arango database (see backend InitialSetup).
# VITE_MARITIME_DATABASE=SingaporeMarine
